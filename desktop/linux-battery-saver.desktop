[Desktop Entry]
Type=Application
Name=Linux Battery Saver
GenericName=GPU Power Switch
Comment=Auto-toggle NVIDIA dGPU + system power profile on AC change
Exec=gpu-power-switch-gui --hidden
Icon=battery-full-symbolic
Terminal=false
Categories=Settings;HardwareSettings;
OnlyShowIn=GNOME;XFCE;KDE;MATE;
Keywords=battery;power;gpu;nvidia;optimus;ac;
StartupNotify=true
StartupWMClass=org.linuxbatterysaver.Gui
X-GNOME-Autostart-enabled=true
X-GNOME-Autostart-Delay=3
