#!/bin/bash
# gpu-power-switch-gui — crash-proof launcher for the GTK4/libadwaita frontend.
# If the python process exits unexpectedly (segfault, exception, signal),
# it is respawned after a 1-second delay so the user sees a continuous GUI.
MAX_RESTARTS=10
RESTART_DELAY=1
COUNT=0
while [ $COUNT -lt $MAX_RESTARTS ]; do
    COUNT=$((COUNT + 1))
    /usr/bin/env python3 /usr/lib/gpu-power-switch/gui/gpu-power-switch-gui.py "$@"
    RC=$?
    if [ $RC -eq 0 ]; then
        # Normal exit (user closed the window) — stop respawning.
        exit 0
    fi
    # Crashed — wait briefly then respawn.
    sleep "$RESTART_DELAY"
done
