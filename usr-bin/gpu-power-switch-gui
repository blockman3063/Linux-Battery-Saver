#!/bin/bash
# gpu-power-switch-gui — launcher for the GTK4/libadwaita frontend.
# Resolves the location of the python module. The python module is
# installed at /usr/lib/gpu-power-switch/gui/; this launcher at
# /usr/bin/. They share a basename but live in different parents, so
# we cannot use a relative path.
exec /usr/bin/env python3 /usr/lib/gpu-power-switch/gui/gpu-power-switch-gui.py "$@"
